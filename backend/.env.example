# ─── ChurnShield AI — Backend Environment Variables ───────────────────────────
FLASK_ENV=development
PORT=5000
DEBUG=true
JWT_SECRET_KEY=change-me-production-long-random-string

# MongoDB Atlas live database - required
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/churnshield_db?retryWrites=true&w=majority
MONGO_DB_NAME=churnshield_db

# CORS - local frontend URL while developing. In Vercel, set your deployed frontend URL.
FRONTEND_URL=http://localhost:5173

# First-time MongoDB login users created automatically in users collection
ADMIN_EMAIL=admin@churnshield.ai
ADMIN_PASSWORD=Admin@123
ANALYST_EMAIL=analyst@churnshield.ai
ANALYST_PASSWORD=Analyst@123

# Large upload performance tuning
MAX_UPLOAD_MB=1024
CSV_CHUNK_SIZE=25000
UPLOAD_BATCH_SIZE=5000
SAVE_SOURCE_COLUMNS=false
CUSTOMER_CACHE_TTL_SECONDS=15
CUSTOMER_QUERY_LIMIT=5000
